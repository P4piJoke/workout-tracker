{
  "realm": "workout-tracker",
  "loginTheme": "workout-tracker",
  "emailTheme": "workout-tracker",
  "enabled": true,
  "registrationAllowed": true,
  "verifyEmail": true,
  "roles": {
    "realm": [
      { "name": "user",  "description": "Regular app user" },
      { "name": "admin", "description": "Can manage exercises" }
    ]
  },
  "clients": [
    {
      "clientId": "workout-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    }
  ],
  "defaultRoles": ["user"],
  "smtpServer": {
    "replyToDisplayName": "Workout Admin",
    "fromDisplayName": "Workout Admin",
    "host": "smtp.gmail.com",
    "port": "587",
    "from": "${KC_SMTP_USER}",
    "auth": "true",
    "starttls": "true",
    "user": "${KC_SMTP_USER}",
    "password": "${KC_SMTP_PASSWORD}"
  }
}
